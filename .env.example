# mcp-knowledge2 environment configuration (AS-3 / autonomous mode)
# All env vars required at runtime unless marked OPTIONAL

# ─── Server ────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=info
NODE_ENV=development

# ─── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgres://knowledge_app:devpassword@postgres:5432/knowledge
DATABASE_POOL_MAX=20

# Admin role (separate user with BYPASSRLS), used only for /v1/internal/erase-user
# AND the OAuth-facade signing-key + users-registry layer (these tables live
# outside RLS and need admin-level reads before any user-context exists).
DATABASE_ADMIN_URL=postgres://knowledge_admin:adminpassword@postgres:5432/knowledge

# ─── Auth: OAuth-facade (AS-3 K3/K4/K5) ────────────────────────────────
# Self-issuer URL — appears as `iss` in tokens KC2 issues. Used to compute
# the issuer string in JWT claims and the OAuth-2.0 metadata discovery doc.
SELF_OAUTH_ISSUER=https://knowledge.example.invalid

# Google OAuth client used by /oauth/authorize → Google → /auth/google/callback.
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://knowledge.example.invalid/auth/google/callback

# Optional CSV of allowed Workspace `hd` domains. Empty = any domain.
# Recommended for Pilot setups (per K-D1).
GOOGLE_HD_ALLOWLIST=

# Optional CSV of allowed login emails (strict whitelist). Empty = open
# (any Google-verified email accepted). Non-empty = only listed emails may
# complete OAuth callback. Lower-case match after trim.
# Example: ALLOWED_EMAILS=axelrogg@gmail.com,manuelrogg1@gmail.com
ALLOWED_EMAILS=

# Override only if Google moves the JWKS / issuer (defaults are stable).
# GOOGLE_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
# GOOGLE_ISSUER=https://accounts.google.com

# JWKS cache TTL for both Google + approval2 remote-JWKS (seconds).
JWKS_CACHE_TTL_SECONDS=86400

# ─── Auth: OBO from mcp-approval2 (AS-3 K7) ────────────────────────────
# OPTIONAL. Set both to enable the proxy path: approval2 forwards calls
# with `X-On-Behalf-Of: <jwt>` + `Authorization: Bearer <SERVICE_TOKEN>`.
# When unset, /v1/* only accepts user-JWTs from KC2's own facade.
# MCP_APPROVAL_JWKS_URL=https://approval.example.invalid/.well-known/jwks.json
# MCP_APPROVAL_ISSUER=mcp-approval2

# Service-Account-Bearer for /v1/internal/* and the OBO two-factor.
# Rotated per deploy.
SERVICE_TOKEN=replace-with-32-byte-hex

# ─── KMS (AS-3 K9) ─────────────────────────────────────────────────────
# 'openbao'    — Hetzner pilot, Transit-Engine via OPENBAO_ADDR/TOKEN
# 'cloud_kms'  — GCP business, Cloud-KMS-wrapped master + HKDF derive
# 'hkdf_local' — dev/solo fallback, derive DEK from KMS_MASTER_KEY_B64
KMS_PROVIDER=hkdf_local

# OpenBao (when KMS_PROVIDER=openbao)
# OPENBAO_ADDR=https://openbao.internal:8200
# OPENBAO_TOKEN=replace-with-vault-token
# OPENBAO_TRANSIT_PATH=transit

# Cloud KMS (when KMS_PROVIDER=cloud_kms) — Workload Identity Federation
# preferred (no GOOGLE_APPLICATION_CREDENTIALS file). Pre-issue the
# wrapped master via `gcloud kms encrypt`:
#   echo -n "<32-byte-master-hex>" | xxd -r -p | \
#     gcloud kms encrypt --key=projects/.../cryptoKeys/knowledge2 \
#     --plaintext-file=- --ciphertext-file=- | base64
# CLOUD_KMS_KEY_NAME=projects/my-project/locations/europe-west4/keyRings/knowledge2/cryptoKeys/master
# CLOUD_KMS_WRAPPED_MASTER_B64=replace-with-base64-ciphertext

# HKDF-local (when KMS_PROVIDER=hkdf_local) — 32-byte master key
# Use a strong CSPRNG-generated value. Base64 or hex (64 ascii) accepted.
KMS_MASTER_KEY_B64=replace-with-base64-32-bytes

# ─── Blob Storage ──────────────────────────────────────────────────────
# 's3' (default) — works with AWS S3, Cloudflare R2, Backblaze B2,
#                   Hetzner Object Storage, MinIO (anything S3-API).
# 'gcs'          — native Google Cloud Storage via Workload Identity
#                   Federation (no HMAC keys). Used by the business workspace.
BLOB_PROVIDER=s3
BLOB_BUCKET=knowledge

# S3 path (when BLOB_PROVIDER=s3)
BLOB_ENDPOINT=http://minio:9000
BLOB_REGION=eu-central
BLOB_ACCESS_KEY=minioroot
BLOB_SECRET_KEY=minioroot12345
BLOB_PATH_STYLE=true

# GCS path (when BLOB_PROVIDER=gcs) — Workload Identity preferred,
# GCS_KEY_FILE only for local dev with a downloaded SA JSON.
# GCS_PROJECT_ID=my-gcp-project-id
# GCS_KEY_FILE=/etc/secrets/gcs-sa.json

# ─── Embedding Provider ────────────────────────────────────────────────
# 'cloudflare' (default) = Workers AI via AI Gateway, bge-m3 (1024-dim, multilingual)
# 'vertex'              = Google Vertex AI text-multilingual-embedding-002 (768-dim, legacy)
EMBED_PROVIDER=cloudflare

# Cloudflare Workers AI + AI Gateway (when EMBED_PROVIDER=cloudflare).
# API-Token-Scopes: Workers AI Read + AI Gateway Run.
# AI_GATEWAY_ID optional — when unset, traffic goes directly to Workers AI.
CLOUDFLARE_ACCOUNT_ID=replace-with-cf-account-id
CLOUDFLARE_API_TOKEN=replace-with-cf-api-token
CLOUDFLARE_AI_GATEWAY_ID=mcp-knowledge2
CLOUDFLARE_AI_MODEL=@cf/baai/bge-m3

# Vertex AI (only required when EMBED_PROVIDER=vertex)
# VERTEX_PROJECT=replace-with-gcp-project
# VERTEX_LOCATION=europe-west4
# VERTEX_MODEL=text-multilingual-embedding-002
# VERTEX_SERVICE_ACCOUNT_JSON_PATH=/etc/secrets/vertex-sa.json

# ─── Backup ────────────────────────────────────────────────────────────
# AES-256-GCM master key — also used to encrypt the OAuth-facade private
# keys at rest in `signing_keys` (AS-3 K1).
BACKUP_MASTER_KEY=replace-with-base64-32-bytes
BACKUP_BUCKET=knowledge-backup
BACKUP_RETENTION_DAYS=30

# ─── OPTIONAL ──────────────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=mcp-knowledge2
